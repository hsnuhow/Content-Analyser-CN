# .env.example — 本地開發環境變數範本
# 複製為 .env 後填入實際值。.env 已加入 .gitignore，不會被提交。
#
# 生產環境（Cloud Run）所有金鑰必須透過 Secret Manager 注入，
# 不得使用 .env 檔案。

# ── Flask ──────────────────────────────────────────────────────────────
FLASK_DEBUG=1
SECRET_KEY=dev_secret_key_change_me

# ── Google OAuth（從 GCP Console 取得）────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── GCP Project（Firestore / Vertex AI）───────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── 爬蟲服務（content-crawler）────────────────────────────────────────
# 本地開發時可留空（功能降級），或指向已部署的 Cloud Run URL
CRAWLER_SERVICE_URL=https://content-crawler-xxx.run.app
CRAWLER_API_KEY=your-crawler-api-key

# ── 分析服務（analysis-pipeline）──────────────────────────────────────
# 本地開發時可留空（功能降級），或指向已部署的 Cloud Run URL
ANALYSIS_SERVICE_URL=https://analysis-pipeline-xxx.run.app
ANALYSIS_API_KEY=your-analysis-api-key

# ── 爬蟲 LLM 輔助（content-crawler 內部使用）──────────────────────────
GENAI_API_KEY=your-gemini-api-key-for-crawler-selector

# ── Dev 登入 email（FLASK_DEBUG=1 時使用）────────────────────────────
# 若未設定，Dev 模式會從 Firestore system/config.admin_email 讀取
# DEV_LOGIN_EMAIL=how.penguin@gmail.com
